+        )
+
+    log("mandatory queue complete; entering idle wait loop")
+    while True:
+        time.sleep(POLL_SECONDS)
+
+
+if __name__ == "__main__":
+    try:
+        run_queue()
+    except Exception as exc:
+        log(f"controller failed: {exc}")
+        raise

