+    missing_final_polls = 0
+    while True:
+        result = parse_run_result(run_id)
+        if result["status"] == "ok":
+            return result
+        if active_train_process():
+            missing_final_polls = 0
+        else:
+            missing_final_polls += 1
+            if missing_final_polls >= 3:
