+    size_bytes = int(size_matches[-1])
+    size_ok = "yes" if size_bytes < MAX_SIZE_BYTES else "no"
+    return {
+        "status": "ok",
+        "val_bpb": val_bpb,
+        "size_bytes": size_bytes,
