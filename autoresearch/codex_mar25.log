+
+def run(cmd: list[str], *, check: bool = True, capture: bool = True, env: dict[str, str] | None = None) -> str:
+    result = subprocess.run(
+        cmd,
+        cwd=ROOT,
+        check=check,
+        text=True,
+        capture_output=capture,
+        env=env,
+    )
+    return result.stdout.strip() if capture else ""
+
+
+def log(msg: str) -> None:
